<!-- &#9552;&#9552; LIVE QUESTION COUNT FETCHER &#9552;&#9552;
     Calls Blogger JSON API for each label.
     Updates the count on each subject card + the hero total.
     Falls back gracefully if fetch fails.
&#9552;&#9552; -->
<script>
//<![CDATA[

(function(){

  // All labels to fetch counts for
  var LABELS = [
    'EDC','Analog','Digital','Signals','Control',
    'Communication','EMFT','Microprocessor',
    'Measurements','Networks','Mathematics','Aptitude'
  ];

  var totalPosts = 0;
  var fetched = 0;

  function updateTotal(){
    var el = document.getElementById('total-q-count');
    if(el) el.textContent = totalPosts > 0 ? totalPosts + '+' : '0';
  }

  function fetchLabelCount(label){
    // Blogger Feed API — returns JSON with feed.openSearch$totalResults
    var url = '/feeds/posts/summary/-/' + encodeURIComponent(label) + '?alt=json&max-results=0';

    var s = document.createElement('script');
    var cbName = 'ecv_cb_' + label.replace(/[^a-zA-Z0-9]/g,'_');

    window[cbName] = function(data){
      var el = document.getElementById('cnt-' + label);
      var count = 0;
      try{
        count = parseInt(data.feed.openSearch$totalResults.$t, 10) || 0;
      } catch(e){ count = 0; }

      if(el){
        if(count > 0){
          el.textContent = count + ' MCQs';
          el.className = 'q-count has-q';
        } else {
          el.textContent = 'No questions yet';
          el.className = 'q-count empty';
        }
      }

      totalPosts += count;
      fetched++;
      if(fetched === LABELS.length) updateTotal();

      // cleanup
      delete window[cbName];
      if(s.parentNode) s.parentNode.removeChild(s);
    };

    s.src = url + '&callback=' + cbName;
    s.onerror = function(){
      var el = document.getElementById('cnt-' + label);
      if(el){ el.textContent = '—'; el.className = 'q-count empty'; }
      fetched++;
      if(fetched === LABELS.length) updateTotal();
      delete window[cbName];
      if(s.parentNode) s.parentNode.removeChild(s);
    };

    document.head.appendChild(s);
  }

  // Start fetching after page load (non-blocking)
  if(document.readyState === 'loading'){
    document.addEventListener('DOMContentLoaded', function(){
      LABELS.forEach(fetchLabelCount);
    });
  } else {
    LABELS.forEach(fetchLabelCount);
  }

  // Highlight active label filter link
  document.addEventListener('DOMContentLoaded', function(){
    var path = window.location.pathname + window.location.search;
    document.querySelectorAll('.lf-btn').forEach(function(a){
      a.classList.remove('on');
      var href = a.getAttribute('href') || '';
      if(path === '/' && href === '/'){
        a.classList.add('on');
      } else if(href !== '/' && path.indexOf(encodeURIComponent(a.textContent.trim())) !== -1){
        a.classList.add('on');
      } else if(href !== '/' && path.indexOf(a.textContent.trim()) !== -1){
        a.classList.add('on');
      }
    });
  });

})();

//]]>
</script>

