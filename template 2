/* ══════════════════════════════════════════════
   HEADER SCROLL
══════════════════════════════════════════════ */
(function(){
  document.addEventListener('DOMContentLoaded', function(){

    // Scroll effect
    var hdr = document.querySelector('.hdr');
    if(hdr){
      window.addEventListener('scroll', function(){
        hdr.classList.toggle('scrolled', window.scrollY > 50);
      }, {passive:true});
    }

    // Mobile menu
    var ham = document.getElementById('ham');
    var drawer = document.getElementById('drawer');
    if(ham && drawer){
      var open = false;
      ham.addEventListener('click', function(e){
        e.stopPropagation();
        open = !open;
        drawer.classList.toggle('open', open);
        ham.innerHTML = open ? '<i class="fas fa-times"></i>' : '<i class="fas fa-bars"></i>';
      });
      document.addEventListener('click', function(e){
        if(open && !drawer.contains(e.target) && e.target !== ham){
          open = false;
          drawer.classList.remove('open');
          ham.innerHTML = '<i class="fas fa-bars"></i>';
        }
      });
      drawer.querySelectorAll('a').forEach(function(a){
        a.addEventListener('click', function(){
          open = false;
          drawer.classList.remove('open');
          ham.innerHTML = '<i class="fas fa-bars"></i>';
        });
      });
    }

    // Subject filter tabs (subjects grid)
    document.querySelectorAll('.tab[data-cat]').forEach(function(tab){
      tab.addEventListener('click', function(){
        document.querySelectorAll('.tab[data-cat]').forEach(function(t){t.classList.remove('on');});
        tab.classList.add('on');
        var cat = tab.getAttribute('data-cat');
        document.querySelectorAll('.subject-card[data-cat]').forEach(function(card){
          var c = card.getAttribute('data-cat');
          card.style.display = (cat === 'all' || c === cat) ? '' : 'none';
        });
      });
    });

  });
})();

