  <b:skin><![CDATA[

/* ── VARIABLES ── */
:root{
--bg:#020617;
--bg-card:rgba(15,23,42,0.85);
--bg-glass:rgba(30,41,59,0.55);
--primary:#06b6d4;
--primary-dim:rgba(6,182,212,0.18);
--secondary:#8b5cf6;
--accent:#f59e0b;
--success:#10b981;
--danger:#ef4444;
--warning:#f59e0b;
--txt:#f1f5f9;
--txt-muted:#94a3b8;
--border:rgba(148,163,184,0.13);
--g1:linear-gradient(135deg,#06b6d4,#8b5cf6);
--g2:linear-gradient(135deg,#f59e0b,#ef4444);
--fh:'Orbitron',sans-serif;
--fb:'Inter',sans-serif;
--fm:'JetBrains Mono',monospace;
--glow:0 0 24px rgba(6,182,212,0.18);
}

/* ── RESET ── */
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);color:var(--txt);font-family:var(--fb);
  line-height:1.6;overflow-x:hidden;
  background-image:
    radial-gradient(circle at 15% 40%,rgba(6,182,212,0.07) 0%,transparent 55%),
    radial-gradient(circle at 85% 75%,rgba(139,92,246,0.07) 0%,transparent 55%);
}

/* ── GRID BG ── */
.bg-mesh{
  position:fixed;inset:0;pointer-events:none;z-index:-1;opacity:0.35;
  background-image:
    linear-gradient(rgba(6,182,212,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(6,182,212,0.025) 1px,transparent 1px);
  background-size:48px 48px;
}

/* ── CONTAINER ── */
.wrap{max-width:1380px;margin:0 auto;padding:0 24px;}

/* ═══════════════════════════════════
   HEADER
═══════════════════════════════════ */
.hdr{
  position:fixed;top:0;width:100%;
  background:rgba(2,6,23,0.82);
  backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);
  border-bottom:1px solid var(--border);
  z-index:1000;transition:background 0.3s,box-shadow 0.3s;
}
.hdr.scrolled{background:rgba(2,6,23,0.96);box-shadow:var(--glow);}
.hdr-inner{display:flex;justify-content:space-between;align-items:center;padding:14px 0;}

/* Logo */
.logo{
  font-family:var(--fh);font-size:1.7rem;font-weight:800;
  text-decoration:none;display:flex;align-items:center;gap:10px;
  background:var(--g1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.logo i{font-size:1.9rem;-webkit-text-fill-color:var(--primary);}

/* Nav */
.nav{display:flex;gap:28px;align-items:center;}
.nav a{
  color:var(--txt-muted);text-decoration:none;font-weight:500;font-size:0.9rem;
  position:relative;transition:color 0.3s;
}
.nav a::after{
  content:'';position:absolute;bottom:-4px;left:0;
  width:0;height:2px;background:var(--g1);transition:width 0.3s;
}
.nav a:hover{color:var(--primary);}
.nav a:hover::after{width:100%;}

/* CTA Button */
.btn{
  display:inline-flex;align-items:center;gap:8px;
  padding:10px 22px;border-radius:8px;font-family:var(--fh);
  font-weight:600;font-size:0.85rem;text-decoration:none;
  border:none;cursor:pointer;transition:all 0.3s;
}
.btn-primary{
  background:var(--g1);color:#fff;
  box-shadow:0 4px 16px rgba(6,182,212,0.3);position:relative;overflow:hidden;
}
.btn-primary::before{
  content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,0.18),transparent);
  transition:left 0.5s;
}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(6,182,212,0.45);}
.btn-primary:hover::before{left:100%;}
.btn-ghost{background:transparent;border:1.5px solid var(--primary);color:var(--primary);}
.btn-ghost:hover{background:var(--primary);color:#fff;}

/* Hamburger */
.ham{
  display:none;background:transparent;border:1px solid var(--border);
  color:var(--txt);font-size:1.4rem;padding:7px 13px;border-radius:8px;cursor:pointer;transition:all 0.3s;
}
.ham:hover{border-color:var(--primary);color:var(--primary);}

/* Mobile Drawer */
.drawer{
  display:none;flex-direction:column;
  background:rgba(10,18,38,0.98);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);
  position:fixed;top:68px;left:0;width:100%;height:calc(100vh - 68px);
  padding:1.5rem;gap:0.5rem;z-index:999;
  transform:translateX(110%);transition:transform 0.32s cubic-bezier(0.4,0,0.2,1);overflow-y:auto;
}
.drawer.open{transform:translateX(0);}
.drawer a{
  color:var(--txt);text-decoration:none;font-size:1.1rem;font-family:var(--fh);
  padding:0.9rem 1rem;border-radius:10px;display:flex;align-items:center;gap:12px;
  border:1px solid transparent;transition:all 0.25s;
}
.drawer a:hover,.drawer a:focus{background:var(--bg-glass);border-color:var(--primary);color:var(--primary);}
.drawer .btn-primary{margin-top:1rem;justify-content:center;font-size:1rem;padding:12px;}

/* ═══════════════════════════════════
   HERO
═══════════════════════════════════ */
.hero{padding:130px 0 80px;text-align:center;position:relative;overflow:hidden;}
.hero-glow{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  width:700px;height:700px;border-radius:50%;
  background:radial-gradient(circle,rgba(6,182,212,0.12) 0%,transparent 70%);
  animation:pulse 5s ease-in-out infinite;pointer-events:none;
}
@keyframes pulse{0%,100%{transform:translate(-50%,-50%) scale(1);}50%{transform:translate(-50%,-50%) scale(1.12);}}
.hero h1{
  font-family:var(--fh);font-size:3.4rem;font-weight:800;line-height:1.15;
  margin-bottom:18px;
  background:var(--g1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.hero p{
  font-size:1.2rem;color:var(--txt-muted);max-width:640px;
  margin:0 auto 36px;font-weight:300;
}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}

/* Stats */
.stats{display:flex;justify-content:center;gap:40px;margin-top:54px;flex-wrap:wrap;}
.stat{
  text-align:center;padding:18px 28px;
  background:var(--bg-glass);border:1px solid var(--border);
  border-radius:14px;backdrop-filter:blur(10px);transition:all 0.3s;
}
.stat:hover{transform:translateY(-4px);border-color:var(--primary);box-shadow:var(--glow);}
.stat-n{font-family:var(--fh);font-size:2.2rem;font-weight:700;color:var(--primary);display:block;}
.stat-l{color:var(--txt-muted);font-size:0.8rem;text-transform:uppercase;letter-spacing:1.5px;margin-top:4px;}

/* ── Live badge ── */
.live-badge{
  display:inline-flex;align-items:center;gap:6px;
  padding:5px 14px;border-radius:20px;font-family:var(--fm);font-size:0.75rem;font-weight:600;
  background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.4);color:var(--success);
  margin-bottom:16px;
}
.live-dot{width:7px;height:7px;border-radius:50%;background:var(--success);animation:blink 1.4s infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.3;}}

/* ═══════════════════════════════════
   SECTIONS
═══════════════════════════════════ */
.section{padding:88px 0;position:relative;}
.sec-title{
  text-align:center;font-family:var(--fh);font-size:2.2rem;font-weight:700;
  margin-bottom:12px;
  background:var(--g1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.sec-sub{
  text-align:center;color:var(--txt-muted);font-size:1rem;
  max-width:560px;margin:0 auto 48px;
}

/* ═══════════════════════════════════
   FILTER TABS
═══════════════════════════════════ */
.tabs{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:36px;}
.tab{
  padding:9px 22px;background:var(--bg-glass);border:1px solid var(--border);
  border-radius:50px;color:var(--txt-muted);cursor:pointer;
  transition:all 0.25s;font-weight:500;font-size:0.88rem;
}
.tab:hover,.tab.on{background:var(--primary);border-color:var(--primary);color:#fff;box-shadow:0 4px 14px rgba(6,182,212,0.3);}

/* ═══════════════════════════════════
   SUBJECT CARDS  — now link to real label pages
═══════════════════════════════════ */
.subjects-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(310px,1fr));gap:22px;}
.subject-card{
  background:var(--bg-card);border:1px solid var(--border);
  border-radius:20px;padding:28px;position:relative;overflow:hidden;
  transition:all 0.4s cubic-bezier(0.4,0,0.2,1);
  text-decoration:none;color:inherit;display:block;
}
.subject-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--g1);transform:scaleX(0);transition:transform 0.4s;transform-origin:left;
}
.subject-card:hover{transform:translateY(-7px);border-color:var(--primary);box-shadow:var(--glow);}
.subject-card:hover::before{transform:scaleX(1);}
.s-icon{
  width:58px;height:58px;background:var(--bg-glass);border-radius:14px;
  display:flex;align-items:center;justify-content:center;font-size:1.6rem;
  color:var(--primary);margin-bottom:18px;border:1px solid var(--border);transition:all 0.3s;
}
.subject-card:hover .s-icon{background:var(--primary);color:#fff;transform:scale(1.08) rotate(4deg);}
.subject-card h3{font-family:var(--fh);font-size:1.15rem;margin-bottom:10px;color:#fff;line-height:1.3;}
.subject-card p{color:var(--txt-muted);font-size:0.88rem;margin-bottom:18px;line-height:1.65;}
.s-meta{display:flex;justify-content:space-between;align-items:center;padding-top:16px;border-top:1px solid var(--border);}
.q-count{font-family:var(--fm);font-size:0.82rem;color:var(--primary);font-weight:600;}
.diff{display:flex;gap:4px;}
.d-dot{width:7px;height:7px;border-radius:50%;background:var(--border);}
.d-dot.on{background:var(--success);box-shadow:0 0 6px var(--success);}

/* ── "0 questions" state ── */
.q-count.empty{color:var(--txt-muted);}
.q-count.has-q{color:var(--primary);}

/* ═══════════════════════════════════
   RECENT QUESTIONS — Blogger blog
═══════════════════════════════════ */
/* Label filter bar above the blog list */
.label-filter{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:28px;justify-content:center;}
.lf-btn{
  padding:8px 18px;background:var(--bg-glass);border:1px solid var(--border);
  border-radius:40px;color:var(--txt-muted);cursor:pointer;
  font-size:0.84rem;font-weight:500;transition:all 0.25s;text-decoration:none;
}
.lf-btn:hover,.lf-btn.on{background:var(--primary);border-color:var(--primary);color:#fff;}

/* Blog post list */
.blog-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;}
.blog-card{
  background:var(--bg-card);border:1px solid var(--border);
  border-radius:18px;padding:26px;transition:all 0.35s;
  display:flex;flex-direction:column;gap:12px;
}
.blog-card:hover{transform:translateY(-4px);border-color:var(--primary);box-shadow:var(--glow);}
.bl-labels{display:flex;flex-wrap:wrap;gap:7px;}
.lbl{
  background:rgba(6,182,212,0.1);border:1px solid rgba(6,182,212,0.25);
  color:var(--primary);padding:3px 10px;border-radius:20px;
  font-family:var(--fm);font-size:0.72rem;font-weight:600;
}
.blog-card h3{font-family:var(--fh);font-size:0.98rem;line-height:1.45;}
.blog-card h3 a{color:#fff;text-decoration:none;transition:color 0.25s;}
.blog-card h3 a:hover{color:var(--primary);}
.blog-card .snip{color:var(--txt-muted);font-size:0.86rem;line-height:1.65;flex:1;}
.bl-foot{display:flex;gap:14px;color:var(--txt-muted);font-size:0.8rem;padding-top:12px;border-top:1px solid var(--border);}
.bl-foot i{color:var(--primary);}
.view-more-wrap{text-align:center;margin-top:32px;}

/* Empty state */
.empty-state{
  grid-column:1/-1;text-align:center;padding:64px 20px;color:var(--txt-muted);
}
.empty-state i{font-size:2.8rem;opacity:0.35;margin-bottom:16px;display:block;}
.empty-state p{margin-bottom:8px;}
.empty-state code{
  background:var(--bg-glass);padding:2px 8px;border-radius:4px;
  font-family:var(--fm);font-size:0.85rem;color:var(--accent);
}

/* ═══════════════════════════════════
   SINGLE POST VIEW
═══════════════════════════════════ */
.post-wrap{max-width:880px;margin:40px auto;padding:0 16px;}
.post-card{
  background:var(--bg-card);border:1px solid var(--border);
  border-radius:22px;padding:36px;
}
.post-label-bar{
  display:inline-flex;align-items:center;gap:8px;padding:7px 16px;
  background:var(--bg-glass);border:1px solid var(--primary);border-radius:50px;
  color:var(--primary);font-family:var(--fm);font-size:0.82rem;font-weight:600;
  margin-bottom:22px;
}
.post-title{
  font-family:var(--fh);font-size:1.35rem;color:#fff;
  margin-bottom:22px;line-height:1.5;
}
.post-body{color:var(--txt-muted);line-height:1.85;font-size:1rem;}
.post-body h1,.post-body h2,.post-body h3{color:#fff;font-family:var(--fh);margin:20px 0 10px;}
.post-body p{margin-bottom:12px;}
.post-body code{
  background:rgba(0,0,0,0.35);padding:2px 7px;border-radius:4px;
  font-family:var(--fm);color:var(--accent);font-size:0.9em;
}
.post-body pre{
  background:rgba(0,0,0,0.35);padding:16px;border-radius:10px;
  overflow-x:auto;border:1px solid var(--border);margin:14px 0;
}
.post-body img{max-width:100%;border-radius:10px;margin:12px 0;}
.post-body a{color:var(--primary);text-decoration:underline;}

/* Back button */
.back-btn{
  display:inline-flex;align-items:center;gap:8px;
  color:var(--txt-muted);text-decoration:none;font-size:0.9rem;
  margin-bottom:20px;transition:color 0.25s;
}
.back-btn:hover{color:var(--primary);}

/* ═══════════════════════════════════
   FEATURES
═══════════════════════════════════ */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:24px;}
.feat-card{
  background:var(--bg-card);border:1px solid var(--border);
  border-radius:18px;padding:28px;text-align:center;transition:all 0.35s;position:relative;overflow:hidden;
}
.feat-card::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:3px;
  background:var(--g1);transform:scaleX(0);transition:transform 0.35s;
}
.feat-card:hover{transform:translateY(-8px);border-color:var(--primary);}
.feat-card:hover::after{transform:scaleX(1);}
.feat-ico{
  width:72px;height:72px;margin:0 auto 20px;background:var(--g1);
  border-radius:20px;display:flex;align-items:center;justify-content:center;
  font-size:1.8rem;color:#fff;transition:transform 0.4s;
}
.feat-card:hover .feat-ico{transform:rotate(360deg);}
.feat-card h3{font-family:var(--fh);font-size:1.1rem;margin-bottom:10px;color:#fff;}
.feat-card p{color:var(--txt-muted);font-size:0.88rem;line-height:1.7;}

/* ═══════════════════════════════════
   FOOTER
═══════════════════════════════════ */
footer{
  background:#010410;padding:56px 0 28px;
  border-top:1px solid var(--border);margin-top:80px;
}
.foot-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:40px;}
.foot-desc{color:var(--txt-muted);line-height:1.8;margin:14px 0 22px;max-width:280px;font-size:0.9rem;}
.foot-h{font-family:var(--fh);font-size:1rem;color:#fff;margin-bottom:16px;}
.foot-links{display:flex;flex-direction:column;gap:10px;}
.foot-links a{color:var(--txt-muted);text-decoration:none;font-size:0.88rem;transition:all 0.25s;}
.foot-links a:hover{color:var(--primary);transform:translateX(4px);}
.social{display:flex;gap:12px;margin-top:4px;}
.social a{
  width:40px;height:40px;background:var(--bg-card);border:1px solid var(--border);
  border-radius:10px;display:flex;align-items:center;justify-content:center;
  color:var(--txt-muted);font-size:1.1rem;transition:all 0.25s;
}
.social a:hover{background:var(--primary);border-color:var(--primary);color:#fff;transform:translateY(-3px);}
.foot-bar{
  padding-top:26px;border-top:1px solid var(--border);
  display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
}
.foot-bar span{color:var(--txt-muted);font-size:0.84rem;}

/* ═══════════════════════════════════
   SCROLLBAR
═══════════════════════════════════ */
::-webkit-scrollbar{width:8px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--bg-card);border-radius:4px;}
::-webkit-scrollbar-thumb:hover{background:var(--primary);}

/* ── MathJax ── */
mjx-container{font-size:1.05em !important;color:var(--txt) !important;}

/* ═══════════════════════════════════
   RESPONSIVE
═══════════════════════════════════ */
@media(max-width:1024px){.foot-grid{grid-template-columns:1fr 1fr;}}
@media(max-width:768px){
  .nav{display:none;}
  .ham{display:block;}
  .drawer{display:flex;}
  .hero h1{font-size:2rem;}
  .hero p{font-size:1rem;}
  .stats{gap:14px;}
  .stat{padding:14px 18px;}
  .subjects-grid{grid-template-columns:1fr;}
  .feat-grid{grid-template-columns:1fr 1fr;}
  .foot-grid{grid-template-columns:1fr;text-align:center;}
  .foot-desc{max-width:100%;}
  .social{justify-content:center;}
  .foot-bar{flex-direction:column;text-align:center;}
  .post-card{padding:22px;}
  .blog-grid{grid-template-columns:1fr;}
}
@media(max-width:480px){.feat-grid{grid-template-columns:1fr;}.hero h1{font-size:1.65rem;}}

